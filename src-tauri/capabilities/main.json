{
  "identifier": "main-cap",
  "description": "Allow frontend to listen to Tauri events and open URLs/files.",
  "windows": ["main"],
  "permissions": [
    "core:event:default",
    "core:event:allow-listen",
    "core:window:default",
    "core:window:allow-start-dragging",
    "shell:allow-open"
  ]
}




