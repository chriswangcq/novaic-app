# NovAIC Frontend Environment Variables
# 复制此文件为 .env.local 并根据需要修改配置

# ========== API 配置 ==========
# Gateway 服务地址
VITE_GATEWAY_URL=http://127.0.0.1:19999

# MCP 服务地址（Agent 0 默认）
VITE_MCP_URL=http://127.0.0.1:20000/mcp

# ========== VNC/WebSocket 配置 ==========
# vmcontrol 服务端口（新方式，通过 vmcontrol 代理 VNC）
VITE_VMCONTROL_PORT=8080

# 旧版 websockify 端口（兼容性回退）
VITE_WS_PORT=20007

# ========== 开发模式配置 ==========
# 是否启用 Mock API（true/false）
VITE_MOCK_API=false

# 日志级别（debug/info/warn/error）
VITE_LOG_LEVEL=info
